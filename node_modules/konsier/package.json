{
  "name": "konsier",
  "version": "0.2.2",
  "description": "Konsier Node.js/TypeScript SDK",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Konsier/konsier-node.git"
  },
  "homepage": "https://github.com/Konsier/konsier-node#readme",
  "bugs": {
    "url": "https://github.com/Konsier/konsier-node/issues"
  },
  "keywords": [
    "konsier",
    "sdk",
    "node",
    "typescript"
  ],
  "author": "Konsier",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "express": [
        "dist/adapters/express.d.ts"
      ],
      "next": [
        "dist/adapters/next.d.ts"
      ],
      "fastify": [
        "dist/adapters/fastify.d.ts"
      ],
      "hono": [
        "dist/adapters/hono.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js",
      "require": "./dist/adapters/express.cjs"
    },
    "./next": {
      "types": "./dist/adapters/next.d.ts",
      "import": "./dist/adapters/next.js",
      "require": "./dist/adapters/next.cjs"
    },
    "./fastify": {
      "types": "./dist/adapters/fastify.d.ts",
      "import": "./dist/adapters/fastify.js",
      "require": "./dist/adapters/fastify.cjs"
    },
    "./hono": {
      "types": "./dist/adapters/hono.d.ts",
      "import": "./dist/adapters/hono.js",
      "require": "./dist/adapters/hono.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": "^20.17.0 || >=22.9.0"
  },
  "scripts": {
    "build": "tsup",
    "release:bump": "node scripts/release-bump.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
